VITE_API_BASE_URL=https://drone-app-production-54a7.up.railway.app

# Vercel /api プロキシ用（prepare-vercel.mjs — OAuth 直結構成では未使用可）
BACKEND_URL=https://drone-app-production-54a7.up.railway.app
