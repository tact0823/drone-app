# Backend environment variables (Railway / local)
# Copy values from repo root .env.example or docs/railway-env.md

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google OAuth — Railway backend callback URL required in production
# Example: https://your-service.up.railway.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5173/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
JWT_SECRET=
DATABASE_URL=
