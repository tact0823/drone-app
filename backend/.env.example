# Backend environment variables (Railway / local)
# Copy values from repo root .env.example or docs/railway-env.md

# Admin email/password login (required for production)
ADMIN_EMAIL=
ADMIN_PASSWORD=

JWT_SECRET=
DATABASE_URL=
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional — currently paused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Example: https://your-service.up.railway.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
