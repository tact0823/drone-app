{
  "name": "thermo-inspect-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrateCli.ts",
    "seed": "tsx scripts/seedDemo.ts",
    "verify:pdf": "tsx scripts/verifyPdfFlow.ts",
    "verify:llm": "tsx --env-file=../.env scripts/verifyLlmConnectivity.ts",
    "verify:oauth": "tsx --env-file=../.env scripts/verifyOAuthConnectivity.ts",
    "prod:verify": "tsx --env-file=../.env scripts/prodVerify.ts",
    "test": "node --import tsx --env-file=.env.test --test src/tests/**/*.test.ts",
    "security:audit": "tsx scripts/security-audit.ts",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^19.6.0",
    "google-auth-library": "^9.15.1",
    "heic-convert": "^2.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.14.1",
    "puppeteer": "^24.43.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
