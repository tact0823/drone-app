# ===========================================
# ThermoInspect Report — 本番バックエンド用テンプレート
# コピー: cp .env.production.example .env.production
# Railway / Render / Docker 等の環境変数に設定
# 詳細: docs/deploy-guide.md / docs/production-env.md
# ===========================================

NODE_ENV=production
PORT=3000

# --- 本番 URL（Vercel デプロイ後に確定した値に差し替え）---
FRONTEND_URL=https://YOUR_VERCEL_APP.vercel.app
GOOGLE_CALLBACK_URL=https://YOUR_RAILWAY_APP.up.railway.app/api/v1/auth/google/callback

# --- JWT（32文字以上のランダム文字列 — ローカルと別値を使用）---
JWT_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARS
JWT_EXPIRES_IN=24h

# --- Google OAuth（本番用 OAuth Client）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cookie（Vercel frontend + Railway API クロスオリジン）---
COOKIE_SAME_SITE=none

# --- Supabase PostgreSQL（Direct connection 5432 推奨）---
# postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# --- OpenAI GPT-5.5 ---
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# --- 永続ストレージ（Volume マウント推奨）---
UPLOADS_DIR=/data/uploads
REPORTS_DIR=/data/reports
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- PDF 表紙 ---
COMPANY_NAME=ThermoInspect 株式会社
COMPANY_ADDRESS=東京都千代田区
COMPANY_PHONE=03-0000-0000
COMPANY_WEBSITE=https://example.com
