# ===========================================
# ThermoInspect Report — 本番バックエンド用テンプレート
# コピー: cp .env.production.example .env.production
# Railway / Render / Docker 等の環境変数に設定
# 詳細: docs/deploy-guide.md / docs/production-env.md
# ===========================================

NODE_ENV=production
PORT=3000

# --- 本番 URL ---
FRONTEND_URL=https://drone-app-gamma.vercel.app
GOOGLE_CALLBACK_URL=https://drone-app-production-54a7.up.railway.app/api/v1/auth/google/callback

# --- JWT（ローカル .env の JWT_SECRET と同じ値を Railway に設定）---
JWT_SECRET=
JWT_EXPIRES_IN=24h

# --- Google OAuth（本番用 OAuth Client — ローカル .env と同じ ID / Secret を Railway に設定）---
GOOGLE_CLIENT_ID=890322517305-aou15age95rsgs4jeil7k194gmd7ee99.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# --- Cookie（Vercel frontend + Railway API クロスオリジン）---
COOKIE_SAME_SITE=none

# --- Railway PostgreSQL ---
# API サービス（Railway）: ${{Postgres.DATABASE_URL}}
# ローカル migrate / prod:verify: Connect → Public Network URL（*.rlwy.net）
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- OpenAI GPT-5.5 ---
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# --- 永続ストレージ（Volume マウント推奨）---
UPLOADS_DIR=/data/uploads
REPORTS_DIR=/data/reports
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- PDF 表紙 ---
COMPANY_NAME=ThermoInspect 株式会社
COMPANY_ADDRESS=東京都千代田区
COMPANY_PHONE=03-0000-0000
COMPANY_WEBSITE=https://example.com
