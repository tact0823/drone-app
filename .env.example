# ===========================================
# ThermoInspect Report — ローカル開発用
# コピー: copy .env.example .env
# 本番: .env.production.example → ホスト env
# 一覧: docs/production-env.md / docs/vercel-env.md
# ===========================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Frontend (CORS / OAuth redirect) — ローカルのみ ---
FRONTEND_URL=http://localhost:5173

# --- JWT（本番は別値を生成）---
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# --- Google OAuth ---
# 手順: docs/google-oauth-setup.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 省略可 — FRONTEND_URL + /api/v1/auth/google/callback として自動生成
# ローカル: http://localhost:5173/api/v1/auth/google/callback
# 本番:     https://YOUR_VERCEL_APP.vercel.app/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=

# --- Cookie ---
# ローカル / Vercel プロキシ同一オリジン: lax
# API 別ドメイン直叩き: none + Secure + HTTPS
COOKIE_SAME_SITE=lax

# --- Database ---
# ローカル PostgreSQL または Supabase Direct connection (5432)
# Supabase: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/thermo_inspect

# --- OpenAI GPT-5.5（未設定時はテンプレート診断コメント）---
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# --- File storage ---
UPLOADS_DIR=uploads
REPORTS_DIR=storage/reports

# --- Puppeteer (Windows ローカル / Docker / Railway) ---
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=

# --- Company info (PDF cover) ---
COMPANY_NAME=ThermoInspect 株式会社
COMPANY_ADDRESS=東京都千代田区
COMPANY_PHONE=03-0000-0000
COMPANY_WEBSITE=https://example.com

# --- Seed script (optional) ---
# SEED_USER_EMAIL=your@gmail.com
